
# Backend configuration
PORT=5000
NODE_ENV=development

# Supabase Service Role Key - Get from Supabase Dashboard

# MongoDB Atlas configuration (optional). If you want to use MongoDB Atlas,
# set these values and restart the backend. Example URI format:
# mongodb+srv://<username>:<password>@cluster0.mongodb.net
# MONGODB_URI="mongodb+srv://admin1:admin123@loopacc.vzozr5w.mongodb.net/"
#MONGODB_URI="mongodb://localhost:27017/"
MONGODB_URI="mongodb://admin:admin123@ac-wmf8m1f-shard-00-00.vzozr5w.mongodb.net:27017,ac-wmf8m1f-shard-00-01.vzozr5w.mongodb.net:27017,ac-wmf8m1f-shard-00-02.vzozr5w.mongodb.net:27017/loopacc_db?authSource=admin&replicaSet=atlas-l82jsb-shard-0&tls=true"
MONGODB_DB_NAME="loopacc_db"

# Direct URI fallback (bypasses SRV DNS lookups when querySrv fails)
MONGODB_DIRECT_URI="mongodb://admin:admin123@ac-wmf8m1f-shard-00-00.vzozr5w.mongodb.net:27017,ac-wmf8m1f-shard-00-01.vzozr5w.mongodb.net:27017,ac-wmf8m1f-shard-00-02.vzozr5w.mongodb.net:27017/loopacc_db?authSource=admin&replicaSet=atlas-l82jsb-shard-0&tls=true"
MONGODB_FALLBACK_URI="mongodb://127.0.0.1:27017/loopacc_db"
ALLOW_LOCAL_FILE_DB_FALLBACK=true
