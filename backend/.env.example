## The backend uses MongoDB Atlas. Set the following values:
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/"
MONGODB_DB_NAME="loopacc_db"
# Optional direct URI fallback to bypass SRV DNS issues.
# Example format (hosts from Atlas cluster view):
# mongodb://<username>:<password>@host1:27017,host2:27017,host3:27017/?replicaSet=<replicaSetName>&ssl=true&authSource=admin
MONGODB_DIRECT_URI=""
MONGODB_FALLBACK_URI="mongodb://127.0.0.1:27017/loopacc_db"
# In development, set to false to disable automatic local file fallback DB.
ALLOW_LOCAL_FILE_DB_FALLBACK=true

# Backend configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000"

# Email SMTP configuration
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT=587
